# Frontend source is TypeScript-only. Do not track emitted JS beside TS files.
apps/frontend/src/**/*.js

# Python caches and test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Runtime storage and logs
/storage/
/logs/
*.log

