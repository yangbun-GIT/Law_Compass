# Core
NODE_ENV=development
APP_NAME=LawCompass
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=1209600

# Gateway
PORT=3000
API_PREFIX=/api/v1
INTERNAL_AGENT_URL=http://agent:8000
INTERNAL_SERVICE_TOKEN=
REQUEST_TIMEOUT_MS=30000
RETRY_COUNT=1

# Database
POSTGRES_USER=law
POSTGRES_PASSWORD=lawpass
POSTGRES_DB=lawcompass
DATABASE_URL=postgresql://law:lawpass@postgres:5432/lawcompass

# Redis
REDIS_URL=redis://redis:6379
REDIS_STREAM_KEY=video:jobs
REDIS_STREAM_GROUP=video-workers
LOCAL_STORAGE_ROOT=/app/storage
LOCAL_VIEW_URL_EXPIRES_SEC=900
LOCAL_DOWNLOAD_URL_EXPIRES_SEC=300

# Storage
STORAGE_PROVIDER=nas_sftp
STORAGE_DRIVER=nas_sftp

# Synology NAS DS216play file storage. Keep real passwords or key passphrases only in .env.
# Synology SSH may show /volume1/lawcompass internally, but SFTP sessions for this share use /lawcompass.
NAS_HOST=192.168.1.164
NAS_PORT=22
NAS_USER=lawcompass_storage
NAS_PASSWORD=
NAS_PRIVATE_KEY_PATH=
NAS_PRIVATE_KEY_PASSPHRASE=
NAS_BASE_DIR=/lawcompass
NAS_UPLOAD_DIR=/lawcompass/uploads/original
NAS_TMP_DIR=/lawcompass/uploads/tmp
NAS_FRAMES_DIR=/lawcompass/processed/frames
NAS_CLIPS_DIR=/lawcompass/processed/clips
NAS_REPORTS_DIR=/lawcompass/reports
NAS_DB_BACKUP_DIR=/lawcompass/db-backups
NAS_QUARANTINE_DIR=/lawcompass/quarantine

LOCAL_VIDEO_CACHE_DIR=/app/storage/cache
MAX_UPLOAD_MB=500

# S3 is not active in the current MVP. Fill these only when enabling S3.
AWS_REGION=
S3_BUCKET=
S3_PREFIX_RAW=raw
S3_PREFIX_DERIVED=derived
S3_PRESIGNED_POST_EXPIRES=600
S3_PRESIGNED_GET_EXPIRES_VIEW=900
S3_PRESIGNED_GET_EXPIRES_DOWNLOAD=300
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend
VITE_API_BASE_URL=/api/v1

# OpenAI / Agent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SEC=18
ENABLE_OPENAI_ANALYSTS=0
OPENAI_MODEL_PEDESTRIAN=
OPENAI_MODEL_REAR_END=
OPENAI_MODEL_LANE_CHANGE=
OPENAI_MODEL_INTERSECTION=
ANALYZE_TIMEOUT_MS=30000

# Worker frame analysis. Keep disabled unless explicitly validating video observations.
ENABLE_OPENAI_FRAME_ANALYSIS=0
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_FRAME_ANALYSIS_MAX_FRAMES=18
OPENAI_FRAME_ANALYSIS_MAX_OUTPUT_TOKENS=900
VIDEO_EVENT_WINDOW_CLUSTER_GAP_SEC=3.0
VIDEO_EVENT_WINDOW_MAX_CANDIDATES=6
OPENAI_FRAME_ANALYSIS_DETAIL=high
OPENAI_FRAME_ANALYSIS_REASONING_EFFORT=minimal
FRAME_ANALYSIS_FIXTURE_MODE=

# External legal/public APIs. These require separate account or service approval.
LAW_API_OC=
LAW_API_BASE=https://www.law.go.kr/DRF/lawSearch.do
LAW_API_TARGETS=law,prec
DATA_GO_SERVICE_KEY=
DATA_GO_TRAFFIC_URL=
DATA_GO_SEARCH_YEAR=
DATA_GO_SIDO=
DATA_GO_GUGUN=

# KNIA fault-ratio portal collection
KNIA_BASE_URL=https://accident.knia.or.kr
KNIA_REQUEST_DELAY_MS=500
KNIA_TIMEOUT_SEC=15
KNIA_COLLECT_MAX_CHARTS=50
